DATABASE_URL=postgresql://user:password@hostname/dbname
CALLMEBOT_KEY=your_key_here
CALLMEBOT_PHONE=91XXXXXXXXXX
PORT=4000

# Optional: Add Firebase Service Account credentials for Admin SDK
# You only need this if you are initializing Firebase Admin with explicit credentials,
# but it's recommended to export GOOGLE_APPLICATION_CREDENTIALS or set them in Render.
FIREBASE_PROJECT_ID=lapzenix
FIREBASE_CLIENT_EMAIL=your-service-account-email@lapzenix.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
